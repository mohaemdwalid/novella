{%- comment -%}
  Accepts:

  - image: {Image Object} The image object
  - widths: {String} A comma-seperated string of widths

  Usage:
  {%- render 'srcset',
    image: product.featured_media,
    widths: '750,1200,1440,1920' -%}
{%- endcomment -%}

{%- liquid
  assign width_list = widths | default: '375,550,750,1100,1500,1780,2000,3000,3840'
  assign parsed_widths = width_list | split: ','
  if image != blank
    for w in parsed_widths
      assign w_num = w | plus: 0

      if image.width >= w_num
        echo image | image_url: width: w_num | append: ' ' | append: w | append: 'w'
        if forloop.last == false
          echo ','
        endif
      endif
    endfor
  endif
-%}
