    "custom_liquid_location_section": {
      "type": "custom-liquid",
      "settings": {
        "custom_liquid": "<div class=\"location-section\">\n  <hr class=\"section-divider\">\n\n  <div class=\"location-text\">\n    <h1>NOVELLA</h1>\n\n    <h2>أين تجدنا</h2>\n\n    <p>\n      معيذر – شارع الرويضات<br>\n      الدوحة – قطر\n    </p>\n  </div>\n\n  <hr class=\"text-map-divider\">\n\n  <div class=\"map-full\">\n    <iframe\n      src=\"https://www.google.com/maps/embed?pb=!1m17!1m12!1m3!1d3885.139644876634!2d51.406105075384154!3d25.271754977663083!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m2!1m1!2zMjXCsDE2JzE4LjMiTiA1McKwMjQnMzEuMyJF!5e1!3m2!1sen!2sqa!4v1770723326285!5m2!1sen!2sqa\"\n      loading=\"lazy\"\n      referrerpolicy=\"no-referrer-when-downgrade\"\n      allowfullscreen>\n    </iframe>\n  </div>\n</div>\n\n<style>\n@import url('https://fonts.googleapis.com/css2?family=Tajawal:wght@300;400;500;700&display=swap');\n\n.location-section{\n  font-family:'Tajawal', sans-serif;\n}\n\n.location-text{\n  max-width:1000px;\n  margin:0 auto;\n  padding:1px 20px 6px;\n  text-align:center;\n}\n\n.section-divider{\n  border:0;\n  border-top:1px solid #e6e6e6;\n  max-width:1000px;\n  margin:0 auto 90px;\n}\n\n.location-text h1{\n  font-size:14px;\n  letter-spacing:.35em;\n  font-weight:400;\n  margin-bottom:18px;\n}\n\n.location-text h2{\n  font-size:62px;\n  letter-spacing:0;\n  font-weight:300;\n  margin-bottom:22px;\n}\n\n.location-text p{\n  font-size:16px;\n  line-height:1.9;\n  margin-bottom:0;\n}\n\n.text-map-divider{\n  border:0;\n  border-top:1px solid #e6e6e6;\n  max-width:1000px;\n  margin:40px auto;\n}\n\n.map-full{\n  width:100%;\n  margin:60px 0 0;\n  border-top:1px solid #e6e6e6;\n}\n\n.map-full iframe{\n  width:100%;\n  height:420px;\n  border:0;\n  pointer-events:auto;\n}\n\n@media (min-width:1024px){\n  .location-text h1{\n    font-size:16px;\n  }\n\n  .location-text h2{\n    font-size:54px;\n    letter-spacing:0;\n  }\n\n  .location-text p{\n    font-size:18px;\n  }\n\n  .map-full iframe{\n    height:600px;\n  }\n}\n\n@media (min-width:1440px){\n  .location-text h2{\n    font-size:62px;\n    letter-spacing:0;\n  }\n\n  .map-full iframe{\n    height:700px;\n  }\n}\n</style>",
