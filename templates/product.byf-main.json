{
  "sections": {
    "main": {
      "type": "main-product",
      "blocks": {
        "title": {
          "type": "title",
          "settings": {
            "heading_size": "h6",
            "spacing_bottom": "1"
          }
        },
        "price": {
          "type": "price",
          "settings": {
            "spacing_bottom": "1",
            "show_price_tax_info": true,
            "show_price_shipping_info": false,
            "show_price_custom_info": ""
          }
        },
        "description": {
          "type": "description",
          "settings": {
            "spacing_bottom": "4",
            "behaviour": "plain",
            "heading": "",
            "text_truncate": 3,
            "icon": "theme-box",
            "metafield_for_product_variant": "",
            "show_block_content": true
          }
        },
        "variant_picker": {
          "type": "variant_picker",
          "settings": {
            "enable_back_in_stock": false,
            "picker_type": "swatch",
            "variant_options_with_thumbnails": "Color",
            "show_gift_card_options_prices_as_label": false,
            "size_guide_page": "size-guide",
            "sizes_option": "Size",
            "spacing_bottom": "4"
          }
        },
        "buy_buttons": {
          "type": "buy_buttons",
          "settings": {
            "spacing_bottom": "4",
            "show_quantity": true,
            "layout": "inline",
            "show_dynamic_checkout": true,
            "show_gift_card_recipient": false
          }
        }
      },
      "block_order": [
        "title",
        "price",
        "description",
        "variant_picker",
        "buy_buttons"
      ],
      "settings": {
        "product_media_layout": "product__media-layout--grid",
        "product_media_layout_mobile": "product__media-layout--partial--sm",
        "product_media_aspect_ratio": "fit",
        "product_media_object_fit": "cover",
        "product_slider_auto_height": false,
        "media_transparent_background": true,
        "display_media_zoom": "click",
        "product_media_with_thumbs": "only_mobile",
        "product_media_thumbs_ratio": "square",
        "product_media_thumbs_object_fit": "cover",
        "gallery_arrows_show_on": "desktop",
        "display_media_gallery_pagination": "none",
        "media_gallery_info": "",
        "metafield_as_seen_on": "theme.as_seen_on",
        "color_scheme_gallery": "",
        "enable_sticky_info": true,
        "enable_actions_bar": true,
        "media_grid_size": "large",
        "media_grid_position": "start",
        "grid_gap": "2",
        "spacing_grid": 1.6,
        "grid_content_alignment": "start",
        "section_width": "max-w-fluid",
        "color_scheme": "scheme-1",
        "spacing_top": "2",
        "spacing_bottom": "0"
      }
    },
    "recommendations": {
      "type": "product-recommendations",
      "settings": {
        "layout": "layout-1",
        "enable_slideshow_overflow": false,
        "heading": "You may also like",
        "heading_size": "h4",
        "subheading": "",
        "button_label": "View all",
        "button_link": "",
        "button_style": "button--filled",
        "show_navigation_arrows": true,
        "slider_autoplay": 10,
        "tabs_button_style": "tab-btn-filled",
        "max_products": 10,
        "show_unavailable_products": false,
        "section_width": "max-w-fluid",
        "color_scheme": "",
        "spacing_top": "4",
        "spacing_bottom": "4"
      }
    }
  },
  "order": [
    "main",
    "recommendations"
  ]
}
